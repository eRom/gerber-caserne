{
  "name": "agent-brain-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev":        "concurrently -n mcp,ui -c blue,magenta \"pnpm --filter @agent-brain/mcp dev -- --ui\" \"pnpm --filter @agent-brain/ui dev\"",
    "build":      "pnpm --filter @agent-brain/mcp build",
    "test":       "pnpm -r test",
    "typecheck":  "pnpm -r typecheck",
    "mcp:restore": "node packages/mcp/dist/scripts/restore.js",
    "mcp:reindex": "node packages/mcp/dist/scripts/reindex.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0"
}
