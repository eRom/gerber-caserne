{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash ${CLAUDE_PLUGIN_ROOT}/hooks/gerber-poll.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "skill",
            "skill": "session-complete"
          }
        ]
      }
    ]
  }
}
